# 环境变量配置

# LLM API（支持 DeepSeek / OpenAI 兼容接口）
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_PROVIDER=deepseek
LLM_MODELS=deepseek-chat,deepseek-reasoner

# Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRE_DAYS=7

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# 数据目录
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
VECTOR_DB_DIR=./data/vector_db
REPORT_DIR=./data/reports
DATABASE_PATH=./data/learning.db
DB_BACKEND=sqlite
DATABASE_URL=
DB_SSLMODE=require

# 向量数据库
CHUNK_SIZE=500
CHUNK_OVERLAP=50
VECTOR_INDEX_ENABLED=true
VECTOR_BACKEND=chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# HuggingFace 离线模式（模型已下载到本地，无需联网）
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ASR provider: baidu / whisper. Local Whisper is disabled for deploy prep.
ASR_PROVIDER=baidu
LOCAL_WHISPER_ASR_ENABLED=false
BAIDU_ASR_API_KEY=your-baidu-api-key
BAIDU_ASR_SECRET_KEY=your-baidu-secret-key
BAIDU_ASR_CUID=ai-learning-assistant
# 1537 = Mandarin input model in Baidu short speech recognition.
BAIDU_ASR_DEV_PID=1537
# Baidu short speech recognition accepts up to 60s per request; keep this below 60.
BAIDU_ASR_CHUNK_SECONDS=55
BAIDU_ASR_TIMEOUT=30
BAIDU_ASR_FALLBACK_TO_WHISPER=false

# MediaCrawler automation is disabled until it is moved to a worker service.
MEDIACRAWLER_ENABLED=false

# Image OCR for Xiaohongshu image notes.
# Leave OCR_* empty to reuse MULTIMODAL_API_KEY / MULTIMODAL_BASE_URL / MULTIMODAL_MODEL.
IMAGE_OCR_ENABLED=true
IMAGE_OCR_MAX_IMAGES=8
IMAGE_OCR_CACHE=true
OCR_API_KEY=
OCR_BASE_URL=
OCR_MODEL=

# PDF parsing. Set PDF_PARSER=mineru to use MinerU Agent API with PyMuPDF fallback.
PDF_PARSER=pymupdf
MINERU_API_BASE=https://mineru.net/api/v1/agent
MINERU_API_TOKEN=
MINERU_LANGUAGE=ch
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=true
MINERU_IS_OCR=false
MINERU_TIMEOUT=300
MINERU_POLL_INTERVAL=3
